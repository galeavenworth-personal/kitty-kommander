# Launch via: kitty-kommander /path/to/project
# Or: scripts/launch-cockpit.sh /path/to/project
# KITTY_KOMMANDER_SESSION is set by launch-cockpit.sh for per-instance tmux sessions.

# Tab 1: Cockpit — tmux Agent Teams canvas
new_tab Cockpit
layout tall
launch sh -c 'tmux new-session -A -s "${KITTY_KOMMANDER_SESSION:-cockpit}"'

# Tab 2: Driver — Claude Code cell-leader session
new_tab Driver
launch scripts/launch-claude.sh
focus

# Tab 3: Notebooks
new_tab Notebooks
launch euporie notebook

# Tab 4: Dashboard — beads DAG + project health
new_tab Dashboard
layout splits
launch --title "Dependency DAG" python3 scripts/cockpit_dash.py --dag
launch --location=vsplit --title "Project State" python3 scripts/cockpit_dash.py --sidebar
resize_window narrower 10
